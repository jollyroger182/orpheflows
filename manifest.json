{
	"display_information": {
		"name": "orpheflows (dev)",
		"description": "slack workflows pro plus max",
		"background_color": "#384f94"
	},
	"features": {
		"bot_user": {
			"display_name": "orpheflows (dev)",
			"always_online": false
		},
		"slash_commands": [
			{
				"command": "/dev-orpheflows-info",
				"url": "https://orpheflows-dev.example.com/api/slack/slash",
				"description": "Sends an embed with workflow details and an optional message",
				"usage_hint": "<@workflow> [message]",
				"should_escape": true
			},
			{
				"command": "/dev-orpheflows-run",
				"url": "https://orpheflows-dev.example.com/api/slack/slash",
				"description": "Runs an Orpheflows workflow",
				"usage_hint": "<@workflow>",
				"should_escape": true
			}
		],
		"unfurl_domains": ["orpheflows-dev.example.com"]
	},
	"oauth_config": {
		"redirect_urls": ["https://orpheflows-dev.example.com/auth/callback/slack"],
		"scopes": {
			"bot": [
				"commands",
				"im:write",
				"chat:write",
				"chat:write.customize",
				"chat:write.public",
				"links:read",
				"links:write"
			]
		}
	},
	"settings": {
		"event_subscriptions": {
			"request_url": "https://orpheflows-dev.example.com/api/slack/events",
			"bot_events": ["link_shared"]
		},
		"interactivity": {
			"is_enabled": true,
			"request_url": "https://orpheflows-dev.example.com/api/slack/interaction"
		},
		"org_deploy_enabled": false,
		"socket_mode_enabled": false,
		"token_rotation_enabled": false
	}
}
